<%- include('../partials/header') %>
  <div class="auth-page">
    <div class="auth-card">
      <div class="auth-icon"><i class="fas fa-images"></i></div>
      <h1 class="auth-title">Street Gallery</h1>
      <p class="auth-subtitle">Sign in to your street's media collection</p>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
      <% } %>
      <form method="POST" action="/login">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" placeholder="Enter your username" required autofocus>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="Enter your password" required>
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-lg"><i class="fas fa-sign-in-alt"></i> Sign In</button>
      </form>
    </div>
  </div>
<%- include('../partials/footer') %>
