<%- include('../partials/header') %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <style>
    #map { height: calc(100vh - 200px); border-radius: var(--radius); border: 1px solid var(--clr-border); z-index: 1; }
    .leaflet-popup-content { font-family: 'Inter', sans-serif; }
    .leaflet-popup-content a { color: var(--clr-primary); text-decoration: none; font-weight: 600; }
    .leaflet-popup-content img { border-radius: 6px; margin-bottom: 6px; }
  </style>
  <div class="gallery-hero">
    <h1><i class="fas fa-map-marked-alt"></i> Photo Map</h1>
    <p>Geo-tagged media from the community</p>
  </div>

  <% if ((typeof media !== 'undefined' ? media : []).length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-map-marked-alt"></i>
      <p>No geo-tagged media yet — upload photos with GPS coordinates to see them here</p>
    </div>
  <% } else { %>
    <div id="map"></div>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
      var map = L.map('map').setView([20, 78], 5);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; <a href="https://openstreetmap.org/copyright">OpenStreetMap</a>'
      }).addTo(map);

      var bounds = [];
      <% media.forEach(function(item) { %>
        (function() {
          var lat = <%= item.latitude %>, lng = <%= item.longitude %>;
          bounds.push([lat, lng]);
          var thumb = '<%= item.thumbnail ? '/thumbnails/' + item.thumbnail : (item.type === 'photo' ? '/uploads/' + item.filename : '') %>';
          var html = (thumb ? '<img src="' + thumb + '" width="180" height="120" style="object-fit:cover">' : '') +
            '<br><a href="/media/<%= item.id %>"><%= item.title.replace(/'/g, "\\'") %></a>' +
            '<br><span style="font-size:0.8rem;color:#888"><%= item.type %><%= item.category_name ? ' &middot; ' + item.category_name : '' %></span>';
          L.marker([lat, lng]).addTo(map).bindPopup(html);
        })();
      <% }); %>
      if (bounds.length > 1) map.fitBounds(bounds);
    </script>
  <% } %>
<%- include('../partials/footer') %>
