<%- include('../partials/header') %>
  <div class="gallery-hero">
    <h1><%= typeof title !== 'undefined' ? title : 'Gallery' %></h1>
    <p>Browse and enjoy your street's memories</p>
  </div>

  <div class="gallery-controls">
    <div class="category-filters">
      <a href="/<%= currentType ? '?type=' + currentType + '&' : '' %><%= currentSort !== 'newest' ? 'sort=' + currentSort : '' %>" class="filter-chip <%= !currentCategory && !currentType ? 'active' : '' %>"><i class="fas fa-th"></i> All</a>
      <a href="/?type=photo<%= currentCategory ? '&category=' + currentCategory : '' %><%= currentSort !== 'newest' ? '&sort=' + currentSort : '' %>" class="filter-chip <%= currentType === 'photo' ? 'active' : '' %>"><i class="fas fa-camera"></i> Photos</a>
      <a href="/?type=video<%= currentCategory ? '&category=' + currentCategory : '' %><%= currentSort !== 'newest' ? '&sort=' + currentSort : '' %>" class="filter-chip <%= currentType === 'video' ? 'active' : '' %>"><i class="fas fa-video"></i> Videos</a>
      <a href="/?type=audio<%= currentCategory ? '&category=' + currentCategory : '' %><%= currentSort !== 'newest' ? '&sort=' + currentSort : '' %>" class="filter-chip <%= currentType === 'audio' ? 'active' : '' %>"><i class="fas fa-music"></i> Audio</a>
      <a href="/favorites" class="filter-chip <%= typeof isFavoritesPage !== 'undefined' && isFavoritesPage ? 'active' : '' %>"><i class="fas fa-heart"></i> Favorites</a>
      <a href="/watch-later" class="filter-chip <%= typeof isWatchLaterPage !== 'undefined' && isWatchLaterPage ? 'active' : '' %>"><i class="fas fa-clock"></i> Continue</a>
      <a href="/?thisday=1<%= currentType ? '&type=' + currentType : '' %>" class="filter-chip <%= typeof thisDayActive !== 'undefined' && thisDayActive ? 'active' : '' %>"><i class="fas fa-calendar-day"></i> This Day</a>
      <% if (typeof currentTag !== 'undefined' && currentTag) { %>
        <a href="/<%= currentType ? '?type=' + currentType : '' %><%= currentCategory ? (currentType ? '&' : '?') + 'category=' + currentCategory : '' %>" class="filter-chip active"><i class="fas fa-tag"></i> #<%= currentTag %> <span style="margin-left:6px;opacity:0.7">&times;</span></a>
      <% } %>
    </div>
    <div class="gallery-controls-row">
      <div class="category-filters">
        <a href="/<%= currentType ? 'type=' + currentType + '&' : '' %>" class="filter-chip <%= !currentCategory ? 'active' : '' %>"><i class="fas fa-layer-group"></i> All</a>
        <% (typeof categories !== 'undefined' ? categories : []).forEach(function(cat) { %>
          <a href="/?<%= currentType ? 'type=' + currentType + '&' : '' %>category=<%= cat.id %><%= currentSort !== 'newest' ? '&sort=' + currentSort : '' %>" class="filter-chip <%= String(currentCategory) === String(cat.id) ? 'active' : '' %>"><%= cat.name %></a>
        <% }) %>
      </div>
      <div class="sort-controls">
        <label class="sort-label"><i class="fas fa-sort"></i></label>
        <select id="sortSelect" class="sort-select" onchange="applySort(this.value)">
          <option value="newest" <%= currentSort === 'newest' ? 'selected' : '' %>>Newest</option>
          <option value="oldest" <%= currentSort === 'oldest' ? 'selected' : '' %>>Oldest</option>
          <option value="views" <%= currentSort === 'views' ? 'selected' : '' %>>Most Viewed</option>
          <option value="likes" <%= currentSort === 'likes' ? 'selected' : '' %>>Most Liked</option>
          <option value="title" <%= currentSort === 'title' ? 'selected' : '' %>>A-Z</option>
        </select>
      </div>
    </div>
    <div class="gallery-controls-row">
      <div style="display:flex;gap:8px">
        <button class="btn btn-sm btn-secondary" id="slideshowBtn" style="white-space:nowrap"><i class="fas fa-play-circle"></i> Slideshow</button>
        <% if (currentCategory && currentCategory !== '' && currentType !== 'video') { %>
          <a href="/download/category/<%= currentCategory %>" class="btn btn-sm btn-secondary" style="white-space:nowrap"><i class="fas fa-download"></i> Download All</a>
        <% } %>
      </div>
      <form method="GET" action="/" class="search-form">
        <% if (currentCategory) { %><input type="hidden" name="category" value="<%= currentCategory %>"><% } %>
        <% if (currentType) { %><input type="hidden" name="type" value="<%= currentType %>"><% } %>
        <% if (currentSort !== 'newest') { %><input type="hidden" name="sort" value="<%= currentSort %>"><% } %>
        <input type="text" name="search" placeholder="Search title or description..." value="<%= search %>" class="search-input">
        <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-search"></i></button>
      </form>
    </div>
  </div>

  <% if (typeof total !== 'undefined' && total > 0) { %>
    <div class="results-info">
      Showing <%= (currentPage - 1) * 24 + 1 %>–<%= Math.min(currentPage * 24, total) %> of <%= total %> item<%= total !== 1 ? 's' : '' %>
    </div>
  <% } %>

  <% if ((typeof media !== 'undefined' ? media : []).length === 0) { %>
    <div class="empty-state">
      <i class="fas fa-photo-video"></i>
      <% if (typeof isFavoritesPage !== 'undefined' && isFavoritesPage) { %>
        <p><strong>No favorites yet</strong></p>
        <p style="font-size:0.9rem">Click the <i class="fas fa-heart" style="color:var(--clr-danger)"></i> icon on any media to add it to your favorites.</p>
        <a href="/" class="btn btn-primary" style="margin-top:12px"><i class="fas fa-images"></i> Browse Gallery</a>
      <% } else if (typeof isWatchLaterPage !== 'undefined' && isWatchLaterPage) { %>
        <p><strong>No videos in progress</strong></p>
        <p style="font-size:0.9rem">Play a video and your progress will be saved automatically.</p>
        <a href="/" class="btn btn-primary" style="margin-top:12px"><i class="fas fa-video"></i> Browse Videos</a>
      <% } else if (typeof isProfilePage !== 'undefined' && isProfilePage) { %>
        <p><strong>No uploads yet</strong></p>
        <p style="font-size:0.9rem">This member hasn't uploaded any media yet.</p>
      <% } else if (typeof search !== 'undefined' && search) { %>
        <p><strong>No results for "<%= search %>"</strong></p>
        <p style="font-size:0.9rem">Try different keywords or browse the gallery.</p>
        <a href="/" class="btn btn-secondary" style="margin-top:12px"><i class="fas fa-times"></i> Clear Search</a>
      <% } else if (typeof currentTag !== 'undefined' && currentTag) { %>
        <p><strong>No media tagged "<%= currentTag %>"</strong></p>
        <p style="font-size:0.9rem">No items have this tag yet.</p>
        <a href="/" class="btn btn-secondary" style="margin-top:12px"><i class="fas fa-times"></i> Clear Tag Filter</a>
      <% } else if (typeof thisDayActive !== 'undefined' && thisDayActive) { %>
        <p><strong>Nothing on this day</strong></p>
        <p style="font-size:0.9rem">No media was uploaded on this date in previous years.</p>
      <% } else { %>
        <p><strong>No media found</strong></p>
        <p style="font-size:0.9rem">This collection is empty.</p>
        <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
          <a href="/admin/media" class="btn btn-primary" style="margin-top:12px"><i class="fas fa-upload"></i> Upload Media</a>
        <% } %>
      <% } %>
    </div>
  <% } else { %>
    <div class="media-grid">
      <% media.forEach(function(item) { %>
        <a href="/media/<%= item.id %>" class="media-card" data-id="<%= item.id %>" data-type="<%= item.type %>" data-src="/stream/<%= item.id %>">
          <div class="media-card-img">
            <% if (item.thumbnail) { %>
              <img src="/thumbnails/<%= item.thumbnail %>" alt="<%= item.title %>" loading="lazy">
            <% } else if (item.drive_file_id) { %>
              <img src="https://drive.google.com/thumbnail?id=<%= item.drive_file_id %>&sz=w400" alt="<%= item.title %>" loading="lazy">
            <% } else if (item.type === 'photo') { %>
              <img src="/uploads/<%= item.filename %>" alt="<%= item.title %>" loading="lazy">
            <% } else if (item.type === 'audio') { %>
              <div class="media-card-placeholder"><i class="fas fa-music"></i></div>
            <% } else { %>
              <div class="media-card-placeholder"><i class="fas fa-video"></i></div>
            <% } %>
            <% if (typeof item.progress !== 'undefined' && item.progress > 0) { %>
              <div class="progress-bar"><div class="progress-fill" style="width:<%= item.progress %>%"></div></div>
            <% } %>
            <div class="play-badge"><i class="fas fa-<%= item.type === 'video' ? 'play' : (item.type === 'audio' ? 'headphones' : 'expand') %>"></i></div>
            <button class="fav-btn <%= item.isFavorite ? 'fav-active' : '' %>" data-fav-id="<%= item.id %>" onclick="event.preventDefault();event.stopPropagation();toggleFavorite(<%= item.id %>,this)">
              <i class="fas fa-heart"></i>
            </button>
            <div class="media-card-overlay">
              <% if (item.type === 'video') { %>
                <span class="btn btn-sm"><i class="fas fa-play"></i> Play</span>
              <% } else { %>
                <span class="btn btn-sm"><i class="fas fa-expand"></i> View</span>
              <% } %>
            </div>
          </div>
          <div class="media-card-info">
            <h3 class="media-card-title"><%= item.title %></h3>
            <% if (item.description) { %><p class="media-card-desc"><%= item.description.length > 60 ? item.description.slice(0, 60) + '...' : item.description %></p><% } %>
            <div class="media-card-meta">
              <% if (item.category_name) { %><span class="media-tag"><%= item.category_name %></span><% } %>
              <% if (item.tags && item.tags.length) { %><% item.tags.slice(0,2).forEach(function(t) { %><a href="/?tag=<%= encodeURIComponent(t) %><%= currentCategory ? '&category=' + currentCategory : '' %><%= currentType ? '&type=' + currentType : '' %>" class="media-tag media-tag-tag" onclick="event.stopPropagation()"><%= t %></a><% }) %><% } %>
              <span class="media-type-badge"><i class="fas fa-<%= item.type === 'video' ? 'video' : (item.type === 'audio' ? 'music' : 'camera') %>"></i> <%= item.type %></span>
              <% if (item.video_codec) { %>
                <span class="media-tag media-tag-codec <%= ['hevc','h265'].includes(item.video_codec) ? 'codec-warn' : '' %>"><%= item.video_codec.toUpperCase() %></span>
              <% } %>
              <% if (item.drive_file_id) { %><span class="media-tag" style="background:var(--clr-primary-light);color:var(--clr-primary);font-size:0.65rem"><i class="fab fa-google-drive"></i></span><% } %>
              <span class="media-stat"><i class="fas fa-eye"></i> <%= item.views || 0 %></span>
              <span class="media-stat"><i class="fas fa-heart"></i> <%= item.likes || 0 %></span>
            </div>
          </div>
        </a>
      <% }) %>
    </div>

    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (currentPage > 1) { %>
          <a href="<%= buildPageUrl(currentPage - 1) %>" class="btn btn-sm btn-secondary"><i class="fas fa-chevron-left"></i> Prev</a>
        <% } %>
        <span class="pagination-info">Page <%= currentPage %> of <%= totalPages %></span>
        <% if (currentPage < totalPages) { %>
          <a href="<%= buildPageUrl(currentPage + 1) %>" class="btn btn-sm btn-secondary">Next <i class="fas fa-chevron-right"></i></a>
        <% } %>
      </div>
    <% } %>
  <% } %>
  <script>
    function applySort(val) {
      var u = new URL(window.location);
      if (val === 'newest') u.searchParams.delete('sort'); else u.searchParams.set('sort', val);
      u.searchParams.delete('page');
      window.location = u;
    }
    function toggleFavorite(id, btn) {
      fetch('/favorite/' + id, {method:'POST'}).then(function(r){return r.json()}).then(function(d){
        if(d.favorited){btn.classList.add('fav-active'); showToast('Added to favorites', 'success');}
        else{btn.classList.remove('fav-active'); showToast('Removed from favorites', 'success');}
      });
    }
  </script>
<%- include('../partials/footer') %>
